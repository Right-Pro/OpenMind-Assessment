{
  "name": "openmind-assessment",
  "version": "1.0.3",
  "description": "OpenMind Assessment - 开源心理测评系统",
  "main": "dist-electron/main.js",
  "author": "OpenMind Team",
  "license": "MIT",
  "private": true,
  "scripts": {
  "dev": "vite",
  "build": "vite build && electron-builder",
  "build:win": "vite build && electron-builder --win",
  "build:mac": "vite build && electron-builder --mac",
  "build:linux": "vite build && electron-builder --linux",
  "preview": "vite preview",
  "lint": "eslint . --ext .vue,.ts,.tsx --fix"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "ajv": "^8.12.0",
    "better-sqlite3": "^9.4.3",
    "echarts": "^5.5.0",
    "element-plus": "^2.5.6",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-echarts": "^6.6.9",
    "vue-router": "^4.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.20",
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^1.8.27"
  },
  "build": {
  "appId": "com.openmind.assessment",
  "productName": "OpenMind Assessment",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "resources/**/*",
    "node_modules/better-sqlite3/**/*"
  ],
  "extraResources": [
    {
      "from": "resources",
      "to": "resources",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "icon": "build/icon.ico",
    "target": ["nsis", "portable"]
  }
 }
}
